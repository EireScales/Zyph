{
  "name": "zyph",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter zyph-web dev",
    "dev:desktop": "pnpm --filter zyph-desktop dev",
    "build:web": "pnpm --filter zyph-web build",
    "build:desktop": "pnpm --filter zyph-desktop build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=18"
  }
}
